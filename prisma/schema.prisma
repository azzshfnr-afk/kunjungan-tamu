datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tamu {
  id                Int      @id @default(autoincrement())
  namaTamu          String
  asalInstansi      String?
  email             String?
  noTelp            String?
  nik               String?
  karyawanDituju    String?
  departemen        String?
  tujuanKunjungan   String
  tanggalKunjungan  DateTime?
  waktuCheckIn      DateTime
  waktuCheckOut     DateTime
  createdAt         DateTime @default(now())
  status            String   @default("Menunggu Kedatangan")
  nfcId             String?
  fotoKtp           String?
  statusKunjungan   String?  @default("MENUNGGU_GATE_1")
  gedungTujuan      String?
  aksesAktif        String?

  aktualCheckIn     DateTime?
  aktualCheckOut    DateTime?

  anggotaRombongan  AnggotaRombongan[]
}

model AnggotaRombongan {
  id                Int      @id @default(autoincrement())
  nama              String
  email             String?
  noTelp            String?

  tamu              Tamu     @relation(fields: [tamuId], references: [id])
  tamuId            Int
}

model User {
  id          Int     @id @default(autoincrement())
  username    String  @unique  
  password    String           
  role        String  @default("SATPAM_AREA")
  lokasiTugas String?
}

