generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model tamu {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now())
  asalInstansi     String?
  departemen       String?
  email            String?
  jamKunjungan     String?
  karyawanDituju   String?
  namaTamu         String
  nik              String?
  noTelp           String?
  tanggalKunjungan DateTime?
  tujuanKunjungan  String
}
